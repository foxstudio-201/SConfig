{
  "name": "sconfig",
  "private": false,
  "version": "1.0.0",
  "description": "SConfig - Minecraft Server Plugin Configurator",
  "author": "FoxStudio",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --no-open",
    "build": "vite build",
    "lint": "eslint src --ext .js,.jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "generate:icons": "node scripts/generate-icons.mjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run generate:icons && npm run build && electron-builder"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.3.0",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "vite": "^6.0.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.foxstudio.sconfig",
    "productName": "SConfig",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.ico",
      "public/icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Utility",
      "icon": "public/icon.png",
      "maintainer": "FoxStudio <support@foxstudio.site>"
    }
  }
}
